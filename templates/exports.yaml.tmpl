# exports.yaml — {{ROLE_ALIAS}} 對外提供的能力介面
# 一旦其他 Repo 開始 import，這裡的定義就是承諾，不能任意修改

exports:
  skills:
    - alias: "{{SKILL_ALIAS_1}}"
      lite_version: "injections/{{ROLE_ALIAS}}-lite.md"  # 如有精簡版
      description: "{{SKILL_EXPORT_DESCRIPTION_1}}"
      stability: experimental  # experimental | stable | deprecated

  knowledge:
    - type: "{{KNOWLEDGE_TYPE_1}}"  # standards | checklist | reference
      path: "knowledge/{{KNOWLEDGE_PATH_1}}"
      description: "{{KNOWLEDGE_DESCRIPTION_1}}"

  prompts:
    - alias: "{{PROMPT_ALIAS_1}}"
      path: "prompts/{{PROMPT_PATH_1}}"
      description: "{{PROMPT_DESCRIPTION_1}}"
